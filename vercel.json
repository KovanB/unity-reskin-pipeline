{
  "buildCommand": "cd web/frontend && npm install && npm run build",
  "outputDirectory": "web/frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/((?!api|unity).*)", "destination": "/web/frontend/dist/$1" }
  ],
  "headers": [
    {
      "source": "/unity/Build/(.*)\\.gz",
      "headers": [
        { "key": "Content-Encoding", "value": "gzip" }
      ]
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 300
    }
  }
}
