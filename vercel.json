{
  "buildCommand": "cd web/frontend && npm install && npm run build",
  "outputDirectory": "web/frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/((?!api).*)", "destination": "/web/frontend/dist/$1" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 300
    }
  }
}
